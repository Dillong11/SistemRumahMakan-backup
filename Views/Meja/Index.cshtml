@model List<SistemRumahMakan.Models.Meja>

@{
    ViewData["Title"] = "Master Meja";
}

<div class="container mt-4">

    <partial name="_Alert" />

    <div class="card shadow">

        <div class="card-header bg-primary text-white">

            <div class="d-flex justify-content-between align-items-center">

                <h4 class="mb-0">
                    Master Meja
                </h4>

                <a asp-action="Create"
                   class="btn btn-light">
                    + Tambah Meja
                </a>

            </div>

        </div>

        <div class="card-body">

            <form method="get">

                <div class="row mb-3">

                    <div class="col-md-4">

                        <input
                            type="text"
                            class="form-control"
                            name="keyword"
                            placeholder="Cari Nomor Meja..."
                            value="@Context.Request.Query["keyword"]" />

                    </div>

                    <div class="col-md-2">

                        <button class="btn btn-primary">
                            Search
                        </button>

                    </div>

                </div>

            </form>

            <table class="table table-bordered table-hover align-middle">

                <thead class="table-dark">

                    <tr>

                        <th>No</th>
                        <th>Nomor Meja</th>
                        <th>Kapasitas</th>
                        <th>Status</th>
                        <th width="180">Action</th>

                    </tr>

                </thead>

                <tbody>

                    @{
                        int no = 1;
                    }

                    @foreach (var item in Model)
                    {
                        <tr>

                            <td>@no</td>

                            <td>@item.NomorMeja</td>

                            <td>@item.Kapasitas Orang</td>

                            <td>

                                @if (item.Status == "Kosong")
                                {
                                    <span class="badge bg-success">
                                        Kosong
                                    </span>
                                }
                                else if (item.Status == "Terisi")
                                {
                                    <span class="badge bg-danger">
                                        Terisi
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-warning text-dark">
                                        Reservasi
                                    </span>
                                }

                            </td>

                            <td>

                                <a asp-action="Edit"
                                   asp-route-id="@item.Id"
                                   class="btn btn-warning btn-sm">
                                    Edit
                                </a>

                                <a asp-action="Delete"
                                   asp-route-id="@item.Id"
                                   class="btn btn-danger btn-sm">
                                    Delete
                                </a>

                            </td>

                        </tr>

                        no++;
                    }

                </tbody>

            </table>

        </div>

    </div>

</div>