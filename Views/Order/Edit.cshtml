@model SistemRumahMakan.Models.OrderHeader

@{
    ViewData["Title"] = "Edit Transaksi";
}

<div class="container mt-4">

    <div class="card shadow">

        <div class="card-header bg-warning">

            <h4>Edit Transaksi</h4>

        </div>

        <div class="card-body">

            <form asp-action="Edit" method="post">

                <input asp-for="Id" type="hidden" />

                <input asp-for="NomorOrder" type="hidden" />

                <input asp-for="Tanggal" type="hidden" />

                <input asp-for="Total" type="hidden" />

                <div class="mb-3">

                    <label class="form-label">

                        Meja

                    </label>

                    <select asp-for="MejaId"
                            asp-items="ViewBag.Meja"
                            class="form-select">
                    </select>

                </div>

                <div class="mb-3">

                    <label class="form-label">

                        Status

                    </label>

                    <select asp-for="Status"
                            class="form-select">

                        <option value="Proses">
                            Proses
                        </option>

                        <option value="Selesai">
                            Selesai
                        </option>

                        <option value="Batal">
                            Batal
                        </option>

                    </select>

                </div>

                <button class="btn btn-warning">

                    Update

                </button>

                <a asp-action="Index"
                   class="btn btn-secondary">

                    Kembali

                </a>

            </form>

        </div>

    </div>

</div>