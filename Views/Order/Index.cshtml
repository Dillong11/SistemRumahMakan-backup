@model List<SistemRumahMakan.Models.OrderHeader>
@using System.Globalization

@{
    ViewData["Title"] = "Daftar Transaksi";
}

<div class="container mt-4">

    <partial name="_Alert" />

    <div class="card shadow">

        <div class="card-header bg-primary text-white">

            <div class="d-flex justify-content-between align-items-center">

                <h4 class="mb-0">
                    Daftar Transaksi
                </h4>

                <a asp-action="Create" class="btn btn-light">

                    + Transaksi Baru

                </a>

            </div>

        </div>

        <div class="card-body">

            <table class="table table-bordered table-hover">

                <thead class="table-dark">

                    <tr>

                        <th width="5%">No</th>

                        <th>No Order</th>

                        <th>Tanggal</th>

                        <th>Meja</th>

                        <th>Total</th>

                        <th>Status</th>

                        <th width="25%">Action</th>

                    </tr>

                </thead>

                <tbody>

                    @{
                        int no = 1;
                    }

                    @foreach (var item in Model)
                    {
                        <tr>

                            <td>@no</td>

                            <td>

                                @item.NomorOrder

                            </td>

                            <td>

                                @item.Tanggal.ToString("dd-MM-yyyy HH:mm")

                            </td>

                            <td>

                                @item.Meja?.NomorMeja

                            </td>

                            <td>

                                @item.Total.ToString("C0", new CultureInfo("id-ID"))

                            </td>

                            
                            <td>

                                @if (item.Status == "Proses")
                                {
                                    <span class="badge bg-warning text-dark">

                                        Proses

                                    </span>
                                }
                                else if (item.Status == "Selesai")
                                {
                                    <span class="badge bg-success">

                                        Selesai

                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">

                                        Batal

                                    </span>
                                }

                            </td>

                            <td>
                                <a asp-action="Detail" asp-route-id="@item.Id" class="btn btn-info btn-sm">
                                    Detail
                                </a>
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning btn-sm">
                                    Edit
                                </a>

                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm">
                                    Delete
                                </a>
                                <a asp-action="Bayar" asp-route-id="@item.Id" class="btn btn-success btn-sm">
                                    Bayar
                                </a>
                                @if (item.Status == "Selesai")
                                {
                                    <a asp-action="Cetak" asp-route-id="@item.Id" class="btn btn-dark btn-sm">
                                        Struk
                                    </a>
                                }
                            </td>

                        </tr>

                        no++;
                    }

                </tbody>

            </table>

        </div>

    </div>

</div>