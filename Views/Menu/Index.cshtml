@model List<SistemRumahMakan.Models.Menu>
@using System.Globalization

@{
    ViewData["Title"] = "Master Menu";
}

<div class="container mt-4">

    <partial name="_Alert" />

    <div class="card shadow">

        <div class="card-header bg-primary text-white">

            <div class="d-flex justify-content-between align-items-center">

                <h4 class="mb-0">
                    Master Menu
                </h4>

                <a asp-action="Create" class="btn btn-light">
                    + Tambah Menu
                </a>

            </div>

        </div>

        <div class="card-body">

            <form method="get">

                <div class="row mb-3">

                    <div class="col-md-4">

                        <input type="text"
                               class="form-control"
                               name="keyword"
                               placeholder="Cari Menu..."
                               value="@Context.Request.Query["keyword"]" />

                    </div>

                    <div class="col-md-2">

                        <button class="btn btn-primary">
                            Search
                        </button>

                    </div>

                </div>

            </form>

            <table class="table table-bordered table-hover align-middle">

                <thead class="table-dark">

                    <tr>

                        <th>No</th>
                        <th>Foto</th>
                        <th>Nama Menu</th>
                        <th>Kategori</th>
                        <th>Harga</th>
                        <th>Stok</th>
                        <th>Status</th>
                        <th width="180">Action</th>

                    </tr>

                </thead>

                <tbody>

                    @{
                        int no = 1;
                    }

                    @foreach (var item in Model)
                    {
                        <tr>

                            <td>@no</td>

                            <td>

                                @if (!string.IsNullOrEmpty(item.Foto))
                                {
                                    <img src="~/uploads/menu/@item.Foto"
                                         width="70"
                                         height="70"
                                         class="rounded shadow"
                                         style="object-fit:cover;" />
                                }
                                else
                                {
                                    <span class="text-muted">
                                        Tidak Ada
                                    </span>
                                }

                            </td>

                            <td>@item.NamaMenu</td>

                            <td>
                                @item.KategoriMenu?.NamaKategori
                            </td>

                            <td>
                                @item.Harga.ToString("C0", new CultureInfo("id-ID"))
                            </td>

                            <td>
                                @item.Stok
                            </td>

                            <td>

                                @if (item.Status)
                                {
                                    <span class="badge bg-success">
                                        Tersedia
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">
                                        Habis
                                    </span>
                                }

                            </td>

                            <td>

                                <a asp-action="Edit"
                                   asp-route-id="@item.Id"
                                   class="btn btn-warning btn-sm">
                                    Edit
                                </a>

                                <a asp-action="Delete"
                                   asp-route-id="@item.Id"
                                   class="btn btn-danger btn-sm">
                                    Delete
                                </a>

                            </td>

                        </tr>

                        no++;
                    }

                </tbody>

            </table>

        </div>

    </div>

</div>